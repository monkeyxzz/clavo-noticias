{
  "name": "clavo-noticias",
  "main": "src/index.js",
  "compatibility_date": "2026-06-29",
  "compatibility_flags": ["nodejs_compat"],
  // no borrar vars/secrets del dashboard (ej. ADMIN_PASSWORD) en cada deploy
  "keep_vars": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    { "binding": "WALL_KV", "id": "81338d0d376b46a9865a550db3fa3d16" }
  ],
  "routes": [
    { "pattern": "noticias.clavorecords.com", "custom_domain": true }
  ]
}
